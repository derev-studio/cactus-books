#!/bin/bash
# Двойной щелчок по этому файлу — сохранит все изменения и отправит на сайт (GitHub).
# Или в терминале: ./ОТПРАВИТЬ-НА-САЙТ.command
cd "$(dirname "$0")"
echo "Добавляю изменения..."
git add -A
echo "Сохраняю (коммит)..."
git commit -m "Обновление с компьютера: $(date '+%Y-%m-%d %H:%M')" || true
echo "Отправляю на сайт (пуш)..."
git push origin main
echo "Готово. Сайт обновится через 1–2 минуты."
read -p "Нажмите Enter, чтобы закрыть."
